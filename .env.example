# Backend (NestJS)
DATABASE_URL="postgresql://postgres:password@localhost:5432/poetry"
PORT=3001

# Frontend URL (используется для CORS и ссылок в письмах)
FRONTEND_URL=http://localhost:3000

# JWT Secret (в продакшене должен быть секретным)
JWT_SECRET=change-me-in-production

# Email configuration (SMTP) — optional for local development
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASSWORD=

# Legacy SMTP variables (keep for compatibility)
SMTP_USER=
SMTP_PASSWORD=